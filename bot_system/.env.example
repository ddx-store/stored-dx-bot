# ===========================================================================
#  Registration Bot — Environment Variables
#  Copy to .env and fill in your values. Never commit .env to git.
# ===========================================================================

# ── Telegram ──────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Comma-separated Telegram user IDs allowed to use the bot (leave empty = anyone)
TELEGRAM_ALLOWED_USER_IDS=123456789

# ── Fixed password for all registrations ──────────────────────────────────
FIXED_PASSWORD=Hh123456789Hh

# ── Gmail IMAP (App Password — no OAuth needed) ──────────────────────────
# Enable IMAP in Gmail, then create an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
GMAIL_OTP_LABEL=TO_BOT

# ── OTP behaviour ────────────────────────────────────────────────────────
OTP_TIMEOUT_SECONDS=120
OTP_POLL_INTERVAL_SECONDS=5
OTP_MAX_ATTEMPTS=3

# ── Storage ──────────────────────────────────────────────────────────────
# Relative to the working directory. Directory is auto-created.
DB_PATH=data/jobs.db

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
