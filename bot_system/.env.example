# ─────────────────────────────────────────────────────────────────────────────
# Bot System — Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow anyone (not recommended for production).
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# ── Gmail API ──────────────────────────────────────────────────────────────────
# Path to the OAuth2 credentials JSON downloaded from Google Cloud Console.
GMAIL_CREDENTIALS_FILE=credentials.json

# Path where the OAuth2 token will be saved after first login.
GMAIL_TOKEN_FILE=token.json

# Gmail label name that receives OTP emails (create this label in Gmail).
GMAIL_OTP_LABEL=OTP

# ── Target website integration ─────────────────────────────────────────────────
# Base URL of your site's API. No trailing slash.
SITE_API_BASE_URL=https://your-site.com/api/v1

# API key or Bearer token sent as Authorization header.
SITE_API_KEY=your-site-api-key-here

# "api" (default) or "playwright" (browser fallback)
SITE_INTEGRATION_MODE=api

# ── OTP behaviour ──────────────────────────────────────────────────────────────
# How long (seconds) to wait for an OTP email before giving up.
OTP_TIMEOUT_SECONDS=120

# How often (seconds) to check Gmail for new OTP emails.
OTP_POLL_INTERVAL_SECONDS=5

# Maximum OTP submission attempts before failing the job.
OTP_MAX_ATTEMPTS=3

# ── Optional: OTP email filtering ──────────────────────────────────────────────
# Comma-separated partial sender addresses to accept OTP emails from.
# Leave empty to accept any sender.
OTP_ALLOWED_SENDERS=noreply@your-site.com

# Regex pattern that must match the OTP email subject (optional).
OTP_SUBJECT_PATTERN=Verify|Activate|OTP|Code

# How many seconds before job creation to still accept an OTP email.
OTP_LOOKBACK_SECONDS=30

# ── Storage ────────────────────────────────────────────────────────────────────
DB_PATH=bot_system/data/jobs.db

# ── Logging ────────────────────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Network / retries ──────────────────────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF=1.5
