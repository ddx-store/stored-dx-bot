# Required
TELEGRAM_BOT_TOKEN=123456:your-token-from-BotFather

# Optional
# Comma-separated Telegram user IDs that can use admin commands
ADMIN_USER_IDS=
# Comma-separated user IDs allowed to use the bot (empty = public)
ALLOWED_USER_IDS=

# Download limits
# Max file size Telegram bots can upload via Bot API is 50 MB.
# Set to 2000 if you run your own local Bot API server.
MAX_UPLOAD_MB=50
# Hard cap on yt-dlp download size before we try to re-encode / refuse.
MAX_DOWNLOAD_MB=500
# Per-user downloads allowed in the sliding window
RATE_LIMIT_COUNT=5
RATE_LIMIT_WINDOW_SECONDS=60

# Concurrent downloads across the whole bot
MAX_CONCURRENT_DOWNLOADS=4

# Paths
DOWNLOAD_DIR=/tmp/media_bot_downloads
DB_PATH=data/media_bot.db

# Optional yt-dlp cookies file (e.g. for Instagram / private YouTube).
# Path inside the container / machine.
COOKIES_FILE=

# Optional proxy, passed to yt-dlp (e.g. socks5://user:pass@host:1080)
PROXY=

LOG_LEVEL=INFO
